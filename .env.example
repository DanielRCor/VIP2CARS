# VIP2CARS - CONFIGURACIÓN BÁSICA
APP_NAME=VIP2CARS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/VIP2CARS/public

# LOCALIZACIÓN
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

# BASE DE DATOS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vip2cars
DB_USERNAME=root
DB_PASSWORD=

# DRIVERS LOCALES
SESSION_DRIVER=file
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# LOGS
LOG_CHANNEL=stack
LOG_LEVEL=debug

# CORREO
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@vip2cars.pe"
MAIL_FROM_NAME="${APP_NAME}"
